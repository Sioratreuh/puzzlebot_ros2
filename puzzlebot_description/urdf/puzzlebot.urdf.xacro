<?xml version="1.0"?>
<robot name="Puzzlebot_Jetson_Lidar_Ed" xmlns:xacro="http://www.ros.org/wiki/xacro">
  <xacro:include filename="$(find puzzlebot_description)/urdf/sensor.xacro"/>
  <xacro:include filename="$(find puzzlebot_description)/urdf/macros.xacro"/>
  <!-- xacro:include filename="$(find puzzlebot_description)/urdf/puzzlebot_control.xacro"/ -->
  <xacro:include filename="$(find puzzlebot_description)/urdf/sensor_properties.xacro"/>

  <xacro:arg name="prefix" default=""/>

  <material name="green"><color rgba="0.0 1.0 0.0 1.0"/></material>
  <material name="black"><color rgba="0.0 0.0 0.0 1.0"/></material>

  <link name="base_footprint"/>

  <link name="base_link">
    <inertial>
      <mass value="1.0"/>
      <inertia ixx="0.01" iyy="0.01" izz="0.01" ixy="0.0" ixz="0.0" iyz="0.0"/>
    </inertial>
    <visual>
      <origin xyz="-0.052 0 0" rpy="0 0 0"/>
      <geometry>
        <mesh filename="file://$(find puzzlebot_description)/meshes/Puzzlebot_Jetson_Lidar_Edition_Base.stl" scale="1 1 1"/>
      </geometry>
      <material name="green"/>
    </visual>
    <collision>
      <origin xyz="-0.052 0 0" rpy="0 0 0"/>
      <geometry>
        <mesh filename="file://$(find puzzlebot_description)/meshes/Puzzlebot_Jetson_Lidar_Edition_Base.stl" scale="1 1 1"/>
      </geometry>
    </collision>
  </link>

  <link name="wheel_r_link">
    <inertial>
      <mass value="0.1"/>
      <inertia ixx="0.001" iyy="0.001" izz="0.001" ixy="0.0" ixz="0.0" iyz="0.0"/>
    </inertial>
    <visual>
      <origin xyz="0 0 0" rpy="-1.5708 0 0"/>
      <geometry>
        <mesh filename="file://$(find puzzlebot_description)/meshes/Puzzlebot_Wheel.stl" scale="1 1 1"/>
      </geometry>
      <material name="green"/>
    </visual>
    <collision>
      <origin xyz="0 0 0" rpy="-1.5708 0 0"/>
      <geometry>
        <mesh filename="file://$(find puzzlebot_description)/meshes/Puzzlebot_Wheel.stl" scale="1 1 1"/>
      </geometry>
    </collision>
  </link>

  <link name="wheel_l_link">
    <inertial>
      <mass value="0.1"/>
      <inertia ixx="0.001" iyy="0.001" izz="0.001" ixy="0.0" ixz="0.0" iyz="0.0"/>
    </inertial>
    <visual>
      <origin xyz="0 0 0" rpy="1.5708 0 0"/>
      <geometry>
        <mesh filename="file://$(find puzzlebot_description)/meshes/Puzzlebot_Wheel.stl" scale="1 1 1"/>
      </geometry>
      <material name="green"/>
    </visual>
    <collision>
      <origin xyz="0 0 0" rpy="1.5708 0 0"/>
      <geometry>
        <mesh filename="file://$(find puzzlebot_description)/meshes/Puzzlebot_Wheel.stl" scale="1 1 1"/>
      </geometry>
    </collision>
  </link>

  <link name="caster_link">
    <inertial>
      <mass value="0.05"/>
      <inertia ixx="0.0005" iyy="0.0005" izz="0.0005" ixy="0.0" ixz="0.0" iyz="0.0"/>
    </inertial>
    <visual>
      <geometry>
        <mesh filename="file://$(find puzzlebot_description)/meshes/Puzzlebot_Caster_Wheel.stl" scale="1 1 1"/>
      </geometry>
      <material name="green"/>
    </visual>
    <collision>
      <geometry>
        <mesh filename="file://$(find puzzlebot_description)/meshes/Puzzlebot_Caster_Wheel.stl" scale="1 1 1"/>
      </geometry>
    </collision>
  </link>

  <joint name="base_link_joint" type="fixed">
    <parent link="base_footprint"/>
    <child link="base_link"/>
    <origin xyz="0.052 0 0.05"/>
  </joint>

  <joint name="wheel_r_joint" type="continuous">
    <parent link="base_link"/>
    <child link="wheel_r_link"/>
    <origin xyz="0.0 -0.095 -0.0025"/>
    <axis xyz="0 1 0"/>
  </joint>

  <joint name="wheel_l_joint" type="continuous">
    <parent link="base_link"/>
    <child link="wheel_l_link"/>
    <origin xyz="0.0 0.095 -0.0025"/>
    <axis xyz="0 1 0"/>
  </joint>

  <joint name="caster_joint" type="fixed">
    <parent link="base_link"/>
    <child link="caster_link"/>
    <origin xyz="-0.147 0.0 -0.043"/>
  </joint>

  <gazebo reference="wheel_l_link">
    <mu1>0.7</mu1>
    <mu2>0.7</mu2>
    <material>Gazebo/Green</material>
  </gazebo>
  
  <gazebo reference="wheel_r_link">
    <mu1>0.7</mu1>
    <mu2>0.7</mu2>
    <material>Gazebo/Green</material>
  </gazebo>

  <gazebo reference="caster_link">
    <mu1>0.1</mu1>
    <mu2>0.1</mu2>
    <material>Gazebo/Black</material>
  </gazebo>
  
  <gazebo reference="base_link">
    <material>Gazebo/Green</material>
  </gazebo>

  <!-- <xacro:puzzlebot_control prefix="$(arg prefix)"/> -->
  <xacro:rpi_lidar_sensor prefix="$(arg prefix)"/>

</robot>