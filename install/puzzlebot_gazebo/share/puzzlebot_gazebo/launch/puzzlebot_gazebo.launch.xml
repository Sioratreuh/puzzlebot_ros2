<launch>
    <!-- Jose Angel Huerta Rios A01710607 - EQUIPO PAPULAND -->
    <!-- Arguments -->
    <arg name="world" default="$(find-pkg-share puzzlebot_gazebo)/worlds/maze.world"/>
    <arg name="puzzlebot_description_path" default="$(find-pkg-share puzzlebot_description)/launch/puzzlebot_description.launch.xml"/>
    <arg name="gazebo_bridge_config_path" default="$(find-pkg-share puzzlebot_gazebo)/config/gazebo_bridge.yaml"/>
    <arg name="x_pose" default="1.35"/>
    <arg name="y_pose" default="0.0"/>
    <arg name="use_sim_time" default="true"/>
    <arg name="headless" default="false"/>

    <!-- Launch Gazebo -->
    <include if="$(not $(var headless))" file="$(find-pkg-share ros_gz_sim)/launch/gz_sim.launch.py">
        <arg name="gz_args" value="-r $(var world)"/>
    </include>

    <!-- Puzzlebot description -->
    <include file="$(var puzzlebot_description_path)">
        <arg name="use_sim_time" value="$(var use_sim_time)"/>
        <arg name="rviz" value="false"/>
        <arg name="gazebo" value="false"/>
    </include>

    <!-- Spawn robot -->
    <node pkg="ros_gz_sim" exec="create" output="screen"
          args="-name puzzlebot -topic robot_description -x $(var x_pose) -y $(var y_pose) -z 0.1 -Y 3.14159"
          name="spawn_puzzlebot"/>

    <!-- Bridge -->
    <node pkg="ros_gz_bridge" exec="parameter_bridge" output="screen">
        <param name="config_file" value="$(var gazebo_bridge_config_path)"/>
    </node>

</launch>