<?xml version="1.0"?>
<!-- GENERADO CON CLAUDE REMPLAZAR CON ARCHIVOS PROPIOS -->
<launch>
  <arg name="use_sim_time" default="true" description="Use simulation time"/>
  <arg name="map_yaml_file" default="$(find-pkg-share puzzlebot_navigation)/maps/map_maze.yaml"/>
  <arg name="params_file" default="$(find-pkg-share puzzlebot_navigation)/config/nav2_params.yaml"/>
  <arg name="rviz_file" default="$(find-pkg-share puzzlebot_navigation)/rviz/nav2.rviz"/>
  <arg name="use_rviz" default="true" description="Start RViz2 for navigation"/>

  <!-- Map Server -->
  <node pkg="nav2_map_server" exec="map_server" name="map_server" output="screen">
    <param name="yaml_filename" value="$(var map_yaml_file)"/>
    <param name="use_sim_time" value="$(var use_sim_time)"/>
  </node>

  <!-- AMCL (Adaptive Monte Carlo Localization) -->
  <node pkg="nav2_amcl" exec="amcl" name="amcl" output="screen">
    <param name="use_sim_time" value="$(var use_sim_time)"/>
    <param from="$(var params_file)"/>
    <remap from="/scan" to="/scan"/>
  </node>

  <!-- Nav2 Lifecycle Manager -->
  <node pkg="nav2_lifecycle_manager" exec="lifecycle_manager" name="lifecycle_manager_navigation" output="screen">
    <param name="use_sim_time" value="$(var use_sim_time)"/>
    <param name="autostart" value="true"/>
    <param name="node_names" value="map_server,amcl,planner_server,controller_server,recoveries_server,bt_navigator"/>
  </node>

  <!-- Planner Server -->
  <node pkg="nav2_planner" exec="planner_server" name="planner_server" output="screen">
    <param name="use_sim_time" value="$(var use_sim_time)"/>
    <param from="$(var params_file)"/>
  </node>

  <!-- Controller Server -->
  <node pkg="nav2_controller" exec="controller_server" name="controller_server" output="screen">
    <param name="use_sim_time" value="$(var use_sim_time)"/>
    <param from="$(var params_file)"/>
  </node>

  <!-- Recoveries Server -->
  <node pkg="nav2_recoveries" exec="recoveries_server" name="recoveries_server" output="screen">
    <param name="use_sim_time" value="$(var use_sim_time)"/>
    <param from="$(var params_file)"/>
  </node>

  <!-- Behavior Tree Navigator -->
  <node pkg="nav2_bt_navigator" exec="bt_navigator" name="bt_navigator" output="screen">
    <param name="use_sim_time" value="$(var use_sim_time)"/>
    <param from="$(var params_file)"/>
  </node>

  <!-- RViz Visualization for Navigation -->
  <node if="$(var use_rviz)" pkg="rviz2" exec="rviz2" name="rviz2_nav2" args="-d $(var rviz_file)">
    <param name="use_sim_time" value="$(var use_sim_time)"/>
  </node>

</launch>
