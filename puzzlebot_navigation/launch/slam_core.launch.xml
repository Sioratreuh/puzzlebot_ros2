<launch>
  <arg name="slam_params_file" default="$(find-pkg-share puzzlebot_navigation)/config/slam_toolbox.yaml" />
  <arg name="rviz_config_path" default="$(find-pkg-share puzzlebot_navigation)/rviz/slam.rviz" />
  <arg name="use_sim_time" default="true" />
  <arg name="headless" default="false" />

  <!-- SLAM Toolbox node: generates map from laser scan -->
  <node pkg="slam_toolbox" exec="async_slam_toolbox_node" name="slam_toolbox" output="screen">
    <param from="$(var slam_params_file)"/>
    <param name="use_sim_time" value="$(var use_sim_time)"/>
  </node>

  <!-- RViz visualization (skip if headless) -->
  <node pkg="rviz2" exec="rviz2" name="rviz2" output="screen" args="-d $(var rviz_config_path)" unless="$(var headless)">
    <param name="use_sim_time" value="$(var use_sim_time)"/>
  </node>

  <!-- Teleop keyboard control (skip if headless) -->
  <node pkg="teleop_twist_keyboard" exec="teleop_twist_keyboard" name="teleop_keyboard" output="screen" 
        launch-prefix="xterm -e" unless="$(var headless)">
  </node>
</launch>