<?xml version="1.0"?>
<robot name="Puzzlebot_Jetson_Lidar_Ed">

  <material name="green">
    <color rgba="0.0 1.0 0.0 1.0"/>
  </material>
  <material name="black">
    <color rgba="0.0 0.0 0.0 1.0"/>
  </material>

  <link name="base_footprint"/>

  <link name="base_link">
    <inertial>
      <mass value="1.0"/>
      <inertia ixx="0.01" iyy="0.01" izz="0.01" ixy="0.0" ixz="0.0" iyz="0.0"/>
    </inertial>
    <visual>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <geometry>
        <mesh filename="package://puzzlebot_description/meshes/Puzzlebot_Jetson_Lidar_Edition_Base.stl" scale="1 1 1"/>
      </geometry>
      <material name="green"/>
    </visual>
    <collision>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <geometry>
        <mesh filename="package://puzzlebot_description/meshes/Puzzlebot_Jetson_Lidar_Edition_Base.stl" scale="1 1 1"/>
      </geometry>
    </collision>
  </link>

  <link name="wheel_r_link">
    <inertial>
      <mass value="0.1"/>
      <inertia ixx="0.001" iyy="0.001" izz="0.001" ixy="0.0" ixz="0.0" iyz="0.0"/>
    </inertial>
    <visual>
      <origin xyz="0 0 0" rpy="-1.5708 0 0"/>
      <geometry>
        <mesh filename="package://puzzlebot_description/meshes/Puzzlebot_Wheel.stl" scale="1 1 1"/>
      </geometry>
      <material name="green"/>
    </visual>
    <collision>
      <origin xyz="0 0 0" rpy="-1.5708 0 0"/>
      <geometry>
        <mesh filename="package://puzzlebot_description/meshes/Puzzlebot_Wheel.stl" scale="1 1 1"/>
      </geometry>
    </collision>
  </link>

  <link name="wheel_l_link">
    <inertial>
      <mass value="0.1"/>
      <inertia ixx="0.001" iyy="0.001" izz="0.001" ixy="0.0" ixz="0.0" iyz="0.0"/>
    </inertial>
    <visual>
      <origin xyz="0 0 0" rpy="1.5708 0 0"/>
      <geometry>
        <mesh filename="package://puzzlebot_description/meshes/Puzzlebot_Wheel.stl" scale="1 1 1"/>
      </geometry>
      <material name="green"/>
    </visual>
    <collision>
      <origin xyz="0 0 0" rpy="1.5708 0 0"/>
      <geometry>
        <mesh filename="package://puzzlebot_description/meshes/Puzzlebot_Wheel.stl" scale="1 1 1"/>
      </geometry>
    </collision>
  </link>

  <link name="caster_link">
    <inertial>
      <mass value="0.05"/>
      <inertia ixx="0.0005" iyy="0.0005" izz="0.0005" ixy="0.0" ixz="0.0" iyz="0.0"/>
    </inertial>
    <visual>
      <geometry>
        <mesh filename="package://puzzlebot_description/meshes/Puzzlebot_Caster_Wheel.stl" scale="1 1 1"/>
      </geometry>
      <material name="green"/>
    </visual>
    <collision>
      <geometry>
        <mesh filename="package://puzzlebot_description/meshes/Puzzlebot_Caster_Wheel.stl" scale="1 1 1"/>
      </geometry>
    </collision>
  </link>

  <link name="laser_link">
    <inertial>
      <mass value="0.05"/>
      <inertia ixx="0.0005" iyy="0.0005" izz="0.0005" ixy="0.0" ixz="0.0" iyz="0.0"/>
    </inertial>
    <visual>
      <geometry>
        <cylinder radius="0.03" length="0.04"/>
      </geometry>
      <material name="black"/>
    </visual>
    <collision>
      <geometry>
        <cylinder radius="0.03" length="0.04"/>
      </geometry>
    </collision>
  </link>

  <joint name="base_link_joint" type="fixed">
    <parent link="base_footprint"/>
    <child link="base_link"/>
    <origin xyz="0 0 0.05"/>
  </joint>

  <joint name="wheel_r_joint" type="continuous">
    <parent link="base_link"/>
    <child link="wheel_r_link"/>
    <origin xyz="0.052 -0.095 -0.0025"/>
    <axis xyz="0 1 0"/>
  </joint>

  <joint name="wheel_l_joint" type="continuous">
    <parent link="base_link"/>
    <child link="wheel_l_link"/>
    <origin xyz="0.052 0.095 -0.0025"/>
    <axis xyz="0 1 0"/>
  </joint>

  <joint name="caster_joint" type="fixed">
    <parent link="base_link"/>
    <child link="caster_link"/>
    <origin xyz="-0.095 0.0 -0.043"/>
  </joint>

  <joint name="laser_joint" type="fixed">
    <parent link="base_link"/>
    <child link="laser_link"/>
    <origin xyz="0 0 0.1"/>
  </joint>

  <!-- ==================== GAZEBO PLUGINS ==================== -->

  <!-- LiDAR Sensor Plugin -->
  <gazebo reference="laser_link">
    <sensor name="laser_sensor" type="ray">
      <pose>0 0 0 0 0 0</pose>
      <ray>
        <scan>
          <horizontal>
            <samples>360</samples>
            <resolution>1</resolution>
            <min_angle>-3.14159</min_angle>
            <max_angle>3.14159</max_angle>
          </horizontal>
        </scan>
        <range>
          <min>0.12</min>
          <max>12.0</max>
          <resolution>0.01</resolution>
        </range>
        <noise>
          <type>gaussian</type>
          <mean>0.0</mean>
          <stddev>0.01</stddev>
        </noise>
      </ray>
      <plugin filename="ignition-gazebo-ray-sensor-system"
              name="ignition::gazebo::systems::RaySensor">
      </plugin>
      <alwaysOn>1</alwaysOn>
      <visualize>true</visualize>
      <publish_raw_scan>true</publish_raw_scan>
      <topic>scan</topic>
      <frame_id>laser_link</frame_id>
    </sensor>
  </gazebo>

  <!-- Friction configuration for left wheel -->
  <gazebo reference="wheel_l_link">
    <material>Gazebo/Green</material>
    <surface>
      <contact>
        <collide_bitmask>0xffff</collide_bitmask>
      </contact>
      <friction>
        <ode>
          <mu>0.7</mu>
          <mu2>0.7</mu2>
          <slip1>0.0</slip1>
          <slip2>0.0</slip2>
          <fdir1>0 1 0</fdir1>
        </ode>
      </friction>
    </surface>
  </gazebo>

  <!-- Friction configuration for right wheel -->
  <gazebo reference="wheel_r_link">
    <material>Gazebo/Green</material>
    <surface>
      <contact>
        <collide_bitmask>0xffff</collide_bitmask>
      </contact>
      <friction>
        <ode>
          <mu>0.7</mu>
          <mu2>0.7</mu2>
          <slip1>0.0</slip1>
          <slip2>0.0</slip2>
          <fdir1>0 1 0</fdir1>
        </ode>
      </friction>
    </surface>
  </gazebo>

  <!-- Friction configuration for caster wheel -->
  <gazebo reference="caster_link">
    <material>Gazebo/Black</material>
    <surface>
      <contact>
        <collide_bitmask>0xffff</collide_bitmask>
      </contact>
      <friction>
        <ode>
          <mu>0.3</mu>
          <mu2>0.3</mu2>
          <slip1>1.0</slip1>
          <slip2>1.0</slip2>
        </ode>
      </friction>
    </surface>
  </gazebo>

  <!-- Differential Drive Plugin -->
  <gazebo>
    <plugin filename="ignition-gazebo-differential-drive-system"
            name="ignition::gazebo::systems::DifferentialDrive">
      <left_joint>wheel_l_joint</left_joint>
      <right_joint>wheel_r_joint</right_joint>
      <wheel_separation>0.19</wheel_separation>
      <wheel_radius>0.033</wheel_radius>
      <odom_publish_frequency>50</odom_publish_frequency>
      <max_linear_velocity>0.5</max_linear_velocity>
      <max_angular_velocity>2.0</max_angular_velocity>
      <min_linear_velocity>-0.5</min_linear_velocity>
      <min_angular_velocity>-2.0</min_angular_velocity>
      <odom_topic>/odom</odom_topic>
      <tf_topic>/tf</tf_topic>
      <cmd_vel_topic>/cmd_vel</cmd_vel_topic>
    </plugin>
  </gazebo>

  <!-- Base link properties -->
  <gazebo reference="base_link">
    <material>Gazebo/Green</material>
  </gazebo>

  <!-- Caster link properties -->
  <gazebo reference="caster_link">
    <material>Gazebo/Black</material>
  </gazebo>

</robot>