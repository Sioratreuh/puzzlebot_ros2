Panels:
	- Class: rviz_common/Displays
		Help Height: 0
		Name: Displays
		Property Tree Widget:
			Expanded:
				- /Global Options1
				- /Grid1
				- /RobotModel1
				- /TF1
				- /LaserScan1
				- /Map1
				- /Amcl Particle Swarm1
				- /Global Planner1
				- /Controller1
			Splitter Ratio: 0.5
		Tree Height: 0
	- Class: rviz_common/Selection
		Name: Selection
	- Class: rviz_common/Tool Properties
		Name: Tool Properties
	- Class: rviz_common/Views
		Name: Views

Visualization Manager:
	Class: ""
	Displays:
		- Class: rviz_default_plugins/Grid
			Name: Grid
			Enabled: true
			Cell Size: 1
			Plane: XY
			Plane Cell Count: 20
			Reference Frame: map
			Color: 160; 160; 160
			Alpha: 0.5
			Value: true

		- Class: rviz_default_plugins/RobotModel
			Name: RobotModel
			Enabled: true
			Description Source: Topic
			Description Topic:
				Value: /robot_description
			Visual Enabled: true
			Collision Enabled: false

		- Class: rviz_default_plugins/TF
			Name: TF
			Enabled: true
			Frame Timeout: 15
			Show Arrows: true
			Show Axes: true
			Show Names: true
			Marker Scale: 1

		- Class: rviz_default_plugins/LaserScan
			Name: LaserScan
			Enabled: true
			Topic:
				Value: /scan
			Size (m): 0.03
			Style: Flat Squares
			Color: 0; 255; 0
			Alpha: 1
			Decay Time: 0
			Queue Size: 10
			Use Fixed Frame: true

		- Class: rviz_default_plugins/Map
			Name: Map
			Enabled: true
			Topic:
				Value: /map
			Alpha: 0.7
			Color Scheme: map
			Draw Behind: true
			Use Timestamp: false

		- Class: rviz_default_plugins/PoseArray
			Name: Amcl Particle Swarm
			Enabled: true
			Topic:
				Value: /particle_cloud
			Color: 255; 25; 0
			Shape: Arrow (Flat)
			Shaft Length: 0.05
			Shaft Radius: 0.003
			Head Length: 0.02
			Head Radius: 0.006
			Alpha: 0.8

		- Class: rviz_common/Group
			Name: Global Planner
			Enabled: true
			Displays:
				- Class: rviz_default_plugins/Map
					Name: Global Costmap
					Enabled: true
					Topic:
						Value: /global_costmap/costmap
					Alpha: 0.5
					Color Scheme: costmap
					Draw Behind: false
					Use Timestamp: false
				- Class: rviz_default_plugins/Path
					Name: Path
					Enabled: true
					Topic:
						Value: /plan
					Color: 255; 0; 255
					Line Style: Lines
					Line Width: 0.04
					Alpha: 1
				- Class: rviz_default_plugins/Polygon
					Name: Polygon
					Enabled: true
					Topic:
						Value: /global_costmap/published_footprint
					Color: 0; 170; 255
					Alpha: 1

		- Class: rviz_common/Group
			Name: Controller
			Enabled: true
			Displays:
				- Class: rviz_default_plugins/Map
					Name: Local Costmap
					Enabled: true
					Topic:
						Value: /local_costmap/costmap
					Alpha: 0.6
					Color Scheme: costmap
					Draw Behind: false
					Use Timestamp: false
				- Class: rviz_default_plugins/Path
					Name: Local Plan
					Enabled: true
					Topic:
						Value: /local_plan
					Color: 255; 255; 0
					Line Style: Lines
					Line Width: 0.06
					Alpha: 1

	Enabled: true
	Global Options:
		Background Color: 48; 48; 48
		Fixed Frame: map
		Frame Rate: 30
	Name: root
	Tools:
		- Class: rviz_default_plugins/Interact
		- Class: rviz_default_plugins/MoveCamera
		- Class: rviz_default_plugins/Select
		- Class: rviz_default_plugins/FocusCamera
		- Class: rviz_default_plugins/Measure
		- Class: rviz_default_plugins/SetInitialPose
		- Class: rviz_default_plugins/SetGoal
	Views:
		Current:
			Class: rviz_default_plugins/Orbit
			Name: Current View
			Target Frame: base_link
			Distance: 10
			Pitch: 0.7
			Yaw: 0.9
			Focal Point:
				X: 0
				Y: 0
				Z: 0
		Saved: ~

Window Geometry:
	Height: 900
	Width: 1400
