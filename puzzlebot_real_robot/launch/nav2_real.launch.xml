<launch>
    <!-- Nav2 autonomous navigation for physical robot -->
    <!-- Run on laptop while robot executes real_robot_core.launch.xml -->
    <!-- Usage: ros2 launch puzzlebot_real_robot nav2_real.launch.xml [map_path:=/path/to/map.yaml] -->

    <arg name="map_path"
         default="$(find-pkg-share puzzlebot_real_robot)/maps/my_map.yaml"/>
    <arg name="nav2_params_file"
         default="$(find-pkg-share puzzlebot_real_robot)/config/nav2_params_real.yaml"/>
    <arg name="rviz_config_path"
         default="$(find-pkg-share puzzlebot_navigation)/rviz/nav2.rviz"/>

    <!-- Launch robot hardware -->
    <!-- <include file="$(find-pkg-share puzzlebot_real_robot)/launch/real_robot_core.launch.xml"/> -->

    <!-- Nav2 stack: AMCL, costmaps, planners -->
    <include file="$(find-pkg-share nav2_bringup)/launch/bringup_launch.py">
        <arg name="use_sim_time"  value="false"/>
        <arg name="params_file"   value="$(var nav2_params_file)"/>
        <arg name="map"           value="$(var map_path)"/>
    </include>
     <!-- rviz con configuración para Nav2 -->
    <arg name="rviz_config_path"
         default="$(find-pkg-share puzzlebot_navigation)/rviz/nav2.rviz"/>
         
    <!-- RViz visualization -->
    <node pkg="rviz2" exec="rviz2" name="rviz2" output="screen"
          args="-d $(var rviz_config_path)">
        <param name="use_sim_time" value="false"/>
    </node>

</launch>