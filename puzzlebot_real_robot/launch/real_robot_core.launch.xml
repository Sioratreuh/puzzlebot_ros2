<launch>
    <!--
    real_robot_core.launch.xml
    ==========================
    Equivalente a puzzlebot_gazebo en simulación.
    Levanta todo el hardware del Puzzlebot real:
      - micro_ros_agent  -> /VelocityEncR, /VelocityEncL, /cmd_vel
      - RPLiDAR A1       -> /scan
      - robot_state_publisher -> TF estáticos del URDF
      - puzzlebot_localization -> /odom
      - puzzlebot_joint_state_publisher -> /joint_states + TF odom->base_footprint

    Ejecutar EN EL ROBOT (Jetson/Hackerboard).
    -->

    <!-- micro_ros_agent — publica /VelocityEncR, /VelocityEncL, escucha /cmd_vel -->
    <include file="$(find-pkg-share puzzlebot_ros)/launch/micro_ros_agent.launch.py"/>

    <!-- RPLiDAR A1 — publica /scan -->
    <!-- Si el puerto cambia, pasarlo como argumento: serial_port:=/dev/ttyUSB1 -->
    <include file="$(find-pkg-share rplidar_ros)/launch/rplidar_a1_launch.py">
        <arg name="serial_port" value="/dev/ttyUSB1"/>
        <arg name="frame_id"    value="laser_frame"/>
    </include>

    <!-- Robot State Publisher — publica TF estáticos del URDF -->
    <!-- Los tags <gazebo> del URDF se ignoran sin Gazebo activo -->
    <include file="$(find-pkg-share puzzlebot_description)/launch/puzzlebot_description.launch.xml">
        <arg name="use_sim_time" value="false"/>
        <arg name="rviz"         value="false"/>
        <arg name="gazebo"       value="false"/>
    </include>

    <!-- Localization node — lee encoders, publica /odom -->
    <node pkg="puzzlebot_real_robot"
          exec="puzzlebot_localization.py"
          name="puzzlebot_localization"
          output="screen"/>

    <!-- Joint State Publisher — lee /odom, publica /joint_states + TF odom->base_footprint -->
    <node pkg="puzzlebot_real_robot"
          exec="puzzlebot_joint_state_publisher.py"
          name="puzzlebot_joint_state_publisher"
          output="screen"/>

</launch>